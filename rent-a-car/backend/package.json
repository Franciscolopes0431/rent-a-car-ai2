{
  "name": "rent-a-car-backend",
  "version": "1.0.0",
  "description": "Backend MVC para uma aplicacao de rent-a-car com Node.js, Express, PostgreSQL e Sequelize.",
  "main": "server.js",
  "type": "commonjs",
  "engines": { "node": ">=22.12.0" },
  "scripts": {
    "start": "npm run migrate && node server.js",
    "dev": "npm run migrate && nodemon server.js",
    "migrate": "sequelize-cli db:migrate",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.3.0",
    "jsonwebtoken": "^9.0.0",
    "pg": "^8.12.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.3"
  },
  "devDependencies": {
    "nodemon": "^3.1.4",
    "sequelize-cli": "^6.6.2"
  },
  "overrides": {
    "uuid": "11.1.1"
  }
}
